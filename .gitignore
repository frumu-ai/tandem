node_modules/
target/

# Build outputs
dist/
apps/tandem-desktop/src-tauri/target/
*.app
*.dmg
*.exe
*.msi
*.deb
*.AppImage

# Sidecar binaries (downloaded at build time, not committed)
apps/tandem-desktop/src-tauri/binaries/*
!apps/tandem-desktop/src-tauri/binaries/.gitkeep

# Environment and secrets - NEVER COMMIT
.env
.env.*
!.env.example
*.local
secrets/
*.pem
*.key

# Stronghold vault files (user data)
*.stronghold
*.vault

# IDE
.vscode/
!.vscode/extensions.json
.idea/
*.swp
*.swo
.trae/

# OS
.DS_Store
Thumbs.db

# Logs
*.log
npm-debug.log*
*.tgz

# Internal docs (not for repo)
docs/internal/

# External analysis examples
.examples/

# Test coverage
coverage/

# Playwright artifacts
playwright-report/
test-results/

# Python bytecode
__pycache__/
*.pyc

# Tauri
apps/tandem-desktop/src-tauri/gen/

# Tandem
.tandem/
tandem-data/

# Guardrail for mis-scoped automation artifacts; runtime outputs should live under .tandem/.
/artifacts/

# TypeScript
*.tsbuildinfo

logs.txt

# Local scratch / vendor checkouts
.tmp/

# Fastembed Cache
**/.fastembed_cache/
crates/tandem-memory/.fastembed_cache/
apps/tandem-desktop/src-tauri/.fastembed_cache/

# OpenCode workspace runtime (may be generated when the engine starts)
.opencode/

